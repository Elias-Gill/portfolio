---
import { getCollection } from 'astro:content'

const coleccion = "notas"
const notas = await getCollection(coleccion)
---

<section>
    <ul class="hover:underline">
        {
            notas.map(nota => (
                <li class="visited:text-purple hover:underline">
                    <a href={`/${coleccion}/${nota.slug}/`}>{nota.data.titulo}</a>
                </li>
            ))
        }
    </ul>
</section>
