---
import type { CollectionEntry } from 'astro:content'
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

type Props = CollectionEntry<'trabajos'>['data']

const { titulo, descripcion, pubDate, caption } = Astro.props

import '../styles/markdown.css'
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <BaseHead title={titulo} description={descripcion} />
    </head>
    <body class="mx-auto max-w-6xl px-4">
        <Header title={titulo} />
        <main class="my-8">
            <img src={caption} alt="" />
            <h1 class="font-titulo">{titulo}, {pubDate}</h1>
            <article class="markdown-body">
                <hr />
                <slot />
            </article>
        </main>
        <Footer />
    </body>
</html>
